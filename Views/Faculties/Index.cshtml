@model IEnumerable<LibraryWebMvc.Models.Faculty>
@using System.Text.Json

@{
    ViewData["Title"] = "Index";
}

<h1>Список факультетів</h1>

<p>
    <a asp-action="Create" class="create-link">Створити</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Назва факультету</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.FacultyName)
            </td>
            <td>
                    <a asp-action="Edit" asp-route-id="@item.FacultyId" class="action-link">Редагувати</a>
                    <a asp-action="Details" asp-route-id="@item.FacultyId" class="action-link">Детальніше</a>
                    <a asp-action="Delete" asp-route-id="@item.FacultyId" class="action-link">Видалити</a>
            </td>
        </tr>
}
    </tbody>
</table>
<div class="mt-5">
    <h3>Кількість кафедр за факультетами</h3>
    <div class="card border-0 shadow-sm mt-3" style="border-radius: 16px; background-color: #ffffff;">
        <div class="card-body">
            <canvas id="facultiesDepartmentsChart" height="110"></canvas>
        </div>
    </div>
</div>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const facultyLabels = @Html.Raw(JsonSerializer.Serialize(ViewBag.FacultyLabels));
        const facultyCounts = @Html.Raw(JsonSerializer.Serialize(ViewBag.FacultyCounts));

        const facultiesDepartmentsCtx = document.getElementById('facultiesDepartmentsChart');

        new Chart(facultiesDepartmentsCtx, {
            type: 'bar',
            data: {
                labels: facultyLabels,
                datasets: [{
                    label: 'Кількість кафедр',
                    data: facultyCounts
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: true
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            precision: 0
                        }
                    }
                }
            }
        });
    </script>
}
