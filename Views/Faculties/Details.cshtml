@model LibraryWebMvc.Models.Faculty

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Faculty</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.FacultyName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FacultyName)
        </dd>
    </dl>
</div>
<h4>Departments of this faculty</h4>
<hr />

@if (Model.Departments != null && Model.Departments.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Department Name</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var department in Model.Departments)
            {
                <tr>
                    <td>@department.DepartmentName</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No departments are assigned to this faculty.</p>
}
<div>
    <a asp-action="Edit" asp-route-id="@Model?.FacultyId">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
