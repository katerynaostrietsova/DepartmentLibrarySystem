@model LibraryWebMvc.Models.Position

@{
    ViewData["Title"] = "Details";
}

<h1>Деталі</h1>

<div>
    <h4>Посада</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">Назва
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PositionName)
        </dd>
    </dl>
</div>
<h4>Читачі з цією посадою</h4>
<hr />

@if (Model.Readers != null && Model.Readers.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>ПІБ</th>
                <th>Дата реєстрації</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var reader in Model.Readers)
            {
                <tr>
                    <td>@reader.FullName</td>
                    <td>@reader.RegistrationDate</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>Жодного читача з цією посадою не знайдено.</p>
}
<div>
    <a asp-action="Edit" asp-route-id="@Model?.PositionId">Редагувати</a> |
    <a asp-action="Index" class="back-link">Назад до списку</a>
</div>
