@model IEnumerable<LibraryWebMvc.Models.Borrowing>
@using System.Text.Json
@{
    ViewData["Title"] = "Index";
}

<h1>Список  Видач</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="mb-3 d-flex flex-wrap gap-2">
    <a asp-action="Create" class="btn btn-primary">Створити</a>
    <a asp-action="ExportToExcel" class="btn btn-outline-primary">Експорт у Excel</a>
</div>

<form asp-action="ImportFromExcel" method="post" enctype="multipart/form-data" class="mb-4">
    <div class="d-flex flex-wrap gap-2 align-items-center">
        <input type="file" name="file" class="form-control" style="max-width: 320px;" accept=".xlsx" />
        <button type="submit" class="btn btn-outline-success">Імпорт з Excel</button>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>
                Дата видачі
            </th>
            <th>
                Термін повернення
            </th>
            <th>
                Дата повернення
            </th>
            <th>
                Повернено
            </th>
            <th>
                Копія
            </th>
            <th>
                Читач
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.BorrowDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DueDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ReturnDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsReturned)
            </td>
                <td>
                    @item.Copy?.InventoryNumber
                </td>
                <td>
                    @item.Reader?.FullName
                </td>
            <td>
                    <a asp-action="Edit" asp-route-id="@item.BorrowingId" class="action-link">Редагувати</a>
                    <a asp-action="Details" asp-route-id="@item.BorrowingId" class="action-link">Детальніше</a>
                    <a asp-action="Delete" asp-route-id="@item.BorrowingId" class="action-link">Видалити</a>
            </td>
        </tr>
}
    </tbody>
</table>
<div class="mt-5">
    <h3>Повернені та неповернені видачі</h3>
    <div class="card border-0 shadow-sm mt-3" style="border-radius: 16px; background-color: #ffffff;">
        <div class="card-body">
            <canvas id="borrowingsStatusChart" height="110"></canvas>
        </div>
    </div>
</div>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const borrowingStatusLabels = @Html.Raw(JsonSerializer.Serialize(ViewBag.BorrowingStatusLabels));
        const borrowingStatusCounts = @Html.Raw(JsonSerializer.Serialize(ViewBag.BorrowingStatusCounts));

        const borrowingsStatusCtx = document.getElementById('borrowingsStatusChart');

        new Chart(borrowingsStatusCtx, {
            type: 'doughnut',
            data: {
                labels: borrowingStatusLabels,
                datasets: [{
                    label: 'Кількість видач',
                    data: borrowingStatusCounts
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: true
                    }
                }
            }
        });
    </script>
}