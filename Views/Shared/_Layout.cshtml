<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - <th class="actions-col"></th></title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibraryWebMvc.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container">
                <a class="navbar-brand app-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    Кафедральна бібліотека
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Перемкнути навігацію">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-wrap app-menu-list">
                        <li class="nav-item">
                            <a class="nav-link app-link" asp-area="" asp-controller="Home" asp-action="Index">Головна</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-link" asp-controller="Authors" asp-action="Index">Автори</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-link" asp-controller="PublicationTypes" asp-action="Index">Типи видань</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-link" asp-controller="Publishers" asp-action="Index">Видавництва</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-link" asp-controller="Publications" asp-action="Index">Видання</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-link" asp-controller="Faculties" asp-action="Index">Факультети</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-link" asp-controller="Positions" asp-action="Index">Посади</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-link" asp-controller="Departments" asp-action="Index">Кафедри</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-link" asp-controller="Readers" asp-action="Index">Читачі</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-link" asp-controller="Copies" asp-action="Index">Копії видань</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-link" asp-controller="Borrowings" asp-action="Index">Видачі</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="app-page">
        <main class="container app-main">
            <section class="app-content-card">
                @RenderBody()
            </section>
        </main>
    </div>

    <footer class="app-footer">
        <div class="container">
            <span>Кафедральна бібліотека © 2026</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
