@model LibraryWebMvc.Models.Author

@{
    ViewData["Title"] = "Delete";
}

<h1>Видалити</h1>

<h3></h3>
<div>
    <h4>Автор</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            ПІБ
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FullName)
        </dd>
        <dt class = "col-sm-2">
            Рік народження
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.BirthYear)
        </dd>
        <dt class = "col-sm-2">
            Країна
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Country)
        </dd>
    </dl>
    
    <form asp-action="Delete" class="delete-form">
        <input type="hidden" asp-for="AuthorId" />
        <input type="submit" value="Видалити" class="btn btn-danger" />
        <a asp-action="Index" class="back-link">Назад до списку</a>
    </form>
</div>
