@model IEnumerable<LibraryWebMvc.Models.Author>

@{
    ViewData["Title"] = "Index";
}

<h1>Список авторів</h1>

<p>
    <a asp-action="Create" class="create-link">Створити</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                ПІБ
            </th>
            <th>
                РІк народження
            </th>
            <th>
                Країна
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.FullName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.BirthYear)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Country)
            </td>
            <td>
                    <a asp-action="Edit" asp-route-id="@item.AuthorId" class="action-link">Редагувати</a>
                    <a asp-action="Details" asp-route-id="@item.AuthorId" class="action-link">Детальніше</a>
                    <a asp-action="Delete" asp-route-id="@item.AuthorId" class="action-link">Видалити</a>
            </td>
        </tr>
}
    </tbody>
</table>
