@model LibraryWebMvc.Models.Author

@{
    ViewData["Title"] = "Details";
}

<h1>Деталі</h1>

<div>
    <h4>Автор</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">ПІБ
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FullName)
        </dd>
        <dt class = "col-sm-2">Рік народження
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.BirthYear)
        </dd>
        <dt class = "col-sm-2">Країна
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Country)
        </dd>
    </dl>
</div>
<h4>Публікації автора</h4>
<hr />

@if (Model.Publications != null && Model.Publications.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Назва</th>
                <th>Рік</th>
                <th>Видавництво</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var publication in Model.Publications)
            {
                <tr>
                    <td>@publication.Title</td>
                    <td>@publication.Year</td>
                    <td>@publication.Publisher?.Name</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>Не знайдено публікацій автора.</p>
}
<div>
    <a asp-action="Edit" asp-route-id="@Model?.AuthorId">Редагувати</a> |
    <a asp-action="Index" class="back-link">Назад до списку</a>
</div>
