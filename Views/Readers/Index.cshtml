@model IEnumerable<LibraryWebMvc.Models.Reader>
@using System.Text.Json

@{
    ViewData["Title"] = "Index";
}

<h1>Список читачів</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="mb-3 d-flex flex-wrap gap-2">
    <a asp-action="Create" class="btn btn-primary">Створити</a>
    <a asp-action="ExportToExcel" class="btn btn-outline-primary">Експорт у Excel</a>
</div>

<form asp-action="ImportFromExcel" method="post" enctype="multipart/form-data" class="mb-4">
    <div class="d-flex flex-wrap gap-2 align-items-center">
        <input type="file" name="file" class="form-control" style="max-width: 320px;" accept=".xlsx" />
        <button type="submit" class="btn btn-outline-success">Імпорт з Excel</button>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>ПІБ</th>
            <th>Факультет</th>
            <th>Дата реєстрації</th>
            <th>Кафедра</th>
            <th>Посада</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.FullName)
            </td>
                <td>
                    @item.Department?.Faculty?.FacultyName
                </td>
            <td>
                @Html.DisplayFor(modelItem => item.RegistrationDate)
            </td>
                <td>
                    @item.Department?.DepartmentName
                </td>
                <td>
                    @item.Position?.PositionName
                </td>
            <td>
                    <a asp-action="Edit" asp-route-id="@item.ReaderId" class="action-link">Редагувати</a>
                    <a asp-action="Details" asp-route-id="@item.ReaderId" class="action-link">Детальніше</a>
                    <a asp-action="Delete" asp-route-id="@item.ReaderId" class="action-link">Видалити</a>
            </td>
        </tr>
}
    </tbody>
</table>
<div class="mt-5">
    <h3>Кількість читачів за роками реєстрації</h3>
    <div class="card border-0 shadow-sm mt-3" style="border-radius: 16px; background-color: #ffffff;">
        <div class="card-body">
            <canvas id="readersByRegistrationYearChart" height="110"></canvas>
        </div>
    </div>
</div>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const registrationYearLabels = @Html.Raw(JsonSerializer.Serialize(ViewBag.RegistrationYearLabels));
        const registrationYearCounts = @Html.Raw(JsonSerializer.Serialize(ViewBag.RegistrationYearCounts));

        const readersByRegistrationYearCtx = document.getElementById('readersByRegistrationYearChart');

        new Chart(readersByRegistrationYearCtx, {
            type: 'line',
            data: {
                labels: registrationYearLabels,
                datasets: [{
                    label: 'Кількість читачів',
                    data: registrationYearCounts,
                    fill: false,
                    tension: 0.25
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: true
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            precision: 0
                        }
                    }
                }
            }
        });
    </script>
}