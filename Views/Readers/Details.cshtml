@model LibraryWebMvc.Models.Reader

@{
    ViewData["Title"] = "Details";
}

<h1>Деталі</h1>

<div>
    <h4>Читач</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">ПІБ Читача
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FullName)
        </dd>
        <dt class="col-sm-2">
            Факультет
        </dt>
        <dd class="col-sm-10">
            @Model.Department?.Faculty?.FacultyName
        </dd>
        <dt class = "col-sm-2">Дата реєстрації
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.RegistrationDate)
        </dd>
        <dt class="col-sm-2">
            Кафедра
        </dt>
        <dd class="col-sm-10">
            @Model.Department?.DepartmentName
        </dd>
        <dt class="col-sm-2">
            Посада
        </dt>
        <dd class="col-sm-10">
            @Model.Position?.PositionName
        </dd>
    </dl>
</div>
<h4>Видачі цього читача</h4>
<hr />

@if (Model.Borrowings != null && Model.Borrowings.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>ІН копії</th>
                <th>Дата видання</th>
                <th>Термін повернення</th>
                <th>Дата повернення</th>
                <th>Повернено</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var borrowing in Model.Borrowings)
            {
                <tr>
                    <td>@borrowing.Copy?.InventoryNumber</td>
                    <td>@borrowing.BorrowDate</td>
                    <td>@borrowing.DueDate</td>
                    <td>@borrowing.ReturnDate</td>
                    <td>@borrowing.IsReturned</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>Цей читач не мав жодних видач.</p>
}
<div>
    <a asp-action="Edit" asp-route-id="@Model?.ReaderId">Редагувати</a> |
    <a asp-action="Index" class="back-link">Назад до списку</a>
</div>
