@model LibraryWebMvc.Models.Reader

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Reader</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.FullName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FullName)
        </dd>
        <dt class="col-sm-2">
            Faculty
        </dt>
        <dd class="col-sm-10">
            @Model.Department?.Faculty?.FacultyName
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.RegistrationDate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.RegistrationDate)
        </dd>
        <dt class="col-sm-2">
            Department
        </dt>
        <dd class="col-sm-10">
            @Model.Department?.DepartmentName
        </dd>
        <dt class="col-sm-2">
            Position
        </dt>
        <dd class="col-sm-10">
            @Model.Position?.PositionName
        </dd>
    </dl>
</div>
<h4>Borrowings of this reader</h4>
<hr />

@if (Model.Borrowings != null && Model.Borrowings.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Copy</th>
                <th>Borrow Date</th>
                <th>Due Date</th>
                <th>Return Date</th>
                <th>Returned</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var borrowing in Model.Borrowings)
            {
                <tr>
                    <td>@borrowing.Copy?.InventoryNumber</td>
                    <td>@borrowing.BorrowDate</td>
                    <td>@borrowing.DueDate</td>
                    <td>@borrowing.ReturnDate</td>
                    <td>@borrowing.IsReturned</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>This reader has no borrowings.</p>
}
<div>
    <a asp-action="Edit" asp-route-id="@Model?.ReaderId">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
