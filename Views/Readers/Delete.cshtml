@model LibraryWebMvc.Models.Reader

@{
    ViewData["Title"] = "Delete";
}

<h1>Видалити</h1>

<h3></h3>
<div>
    <h4>Читач</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">ПІБ Читача
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FullName)
        </dd>
        <dt class = "col-sm-2">Факультет
        </dt>
        <dd class = "col-sm-10">
            @Model.Department?.Faculty?.FacultyName
        </dd>
        <dt class = "col-sm-2">Дата реєстрації
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.RegistrationDate)
        </dd>
        <dt class = "col-sm-2">Кафедра
        </dt>
        <dd class = "col-sm-10">
            @Model.Department?.DepartmentName
        </dd>
        <dt class = "col-sm-2">Посада
        </dt>
        <dd class = "col-sm-10">
            @Model.Position?.PositionName
        </dd>
    </dl>
    
    <form asp-action="Delete" class="delete-form">
        <input type="hidden" asp-for="ReaderId" />
        <input type="submit" value="Видалити" class="btn btn-danger" />
        <a asp-action="Index" class="back-link">Назад до списку</a>
    </form>
</div>
