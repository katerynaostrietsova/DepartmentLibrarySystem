@model IEnumerable<LibraryWebMvc.Models.Department>
@using System.Text.Json

@{
    ViewData["Title"] = "Index";
}

<h1>Список кафедр</h1>

<p>
    <a asp-action="Create" class="create-link">Створити</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Назва кафедри</th>
            <th>Факультет</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.DepartmentName</td>
            <td>@item.Faculty?.FacultyName</td>
            <td class="actions-col">
                    <a asp-action="Edit" asp-route-id="@item.DepartmentId" class="action-link">Редагувати</a>
                    <a asp-action="Details" asp-route-id="@item.DepartmentId" class="action-link">Детальніше</a>
                    <a asp-action="Delete" asp-route-id="@item.DepartmentId" class="action-link">Видалити</a>
            </td>
        </tr>
    }
    </tbody>
</table>
<div class="mt-5">
    <h3>Кількість читачів за кафедрами</h3>
    <div class="card border-0 shadow-sm mt-3" style="border-radius: 16px; background-color: #ffffff;">
        <div class="card-body">
            <canvas id="departmentsReadersChart" height="110"></canvas>
        </div>
    </div>
</div>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const departmentLabels = @Html.Raw(JsonSerializer.Serialize(ViewBag.DepartmentLabels));
        const departmentCounts = @Html.Raw(JsonSerializer.Serialize(ViewBag.DepartmentCounts));

        const departmentsReadersCtx = document.getElementById('departmentsReadersChart');

        new Chart(departmentsReadersCtx, {
            type: 'bar',
            data: {
                labels: departmentLabels,
                datasets: [{
                    label: 'Кількість читачів',
                    data: departmentCounts
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: true
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            precision: 0
                        }
                    }
                }
            }
        });
    </script>
}