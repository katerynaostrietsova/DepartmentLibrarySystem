@model LibraryWebMvc.Models.Department

@{
    ViewData["Title"] = "Delete";
}

<h1>Видалити</h1>

<h3></h3>
<div>
    <h4>Кафедра</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">Назва
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DepartmentName)
        </dd>
        <dt class = "col-sm-2">Факультет
        </dt>
        <dd class = "col-sm-10">
            @Model.Faculty?.FacultyName
        </dd>
    </dl>
    
    <form asp-action="Delete" class="delete-form">
        <input type="hidden" asp-for="DepartmentId" />
        <input type="submit" value="Видалити" class="btn btn-danger" />
        <a asp-action="Index" class="back-link">Назад до списку</a>
    </form>
</div>
