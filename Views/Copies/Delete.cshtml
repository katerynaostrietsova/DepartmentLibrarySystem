@model LibraryWebMvc.Models.Copy

@{
    ViewData["Title"] = "Delete";
}

<h1>Видалити</h1>

<h3></h3>
<div>
    <h4>Копія</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">ІН Копії
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.InventoryNumber)
        </dd>
        <dt class = "col-sm-2">Дата надходження
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.AcquisitionDate)
        </dd>
        <dt class = "col-sm-2">Доступність
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IsAvailable)
        </dd>
        <dt class = "col-sm-2">Видання
        </dt>
        <dd class = "col-sm-10">
            @Model.Publication?.Title
        </dd>
    </dl>
    
    <form asp-action="Delete" class="delete-form">
        <input type="hidden" asp-for="CopyId" />
        <input type="submit" value="Видалити" class="btn btn-danger" />
        <a asp-action="Index" class="back-link">Назад до списку</a>
    </form>
</div>
