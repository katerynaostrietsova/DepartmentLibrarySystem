@model LibraryWebMvc.Models.Publisher

@{
    ViewData["Title"] = "Details";
}

<h1>Деталі</h1>

<div>
    <h4>Видавництво</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">Назва
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">Місто
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.City)
        </dd>
    </dl>
</div>
<h4>Видання цього видавництва</h4>
<hr />

@if (Model.Publications != null && Model.Publications.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Назва</th>
                <th>Рік</th>
                <th>Мова</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var publication in Model.Publications)
            {
                <tr>
                    <td>@publication.Title</td>
                    <td>@publication.Year</td>
                    <td>@publication.Language</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>У видавництва немає жодного видання.</p>
}
<div>
    <a asp-action="Edit" asp-route-id="@Model?.PublisherId">Редагувати</a> |
    <a asp-action="Index" class="back-link">Назад до списку</a>
</div>
