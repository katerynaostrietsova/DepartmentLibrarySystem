@model IEnumerable<LibraryWebMvc.Models.Publication>

@{
    ViewData["Title"] = "Index";
}

<h1>Список видань</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Title)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Annotation)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Year)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Language)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PublicationType)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Publisher)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Title)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Annotation)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Year)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Language)
            </td>
                <td>
                    @item.PublicationType?.TypeName
                </td>
                <td>
                    @item.Publisher?.Name
                </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.PublicationId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.PublicationId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.PublicationId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
