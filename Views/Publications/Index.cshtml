@model IEnumerable<LibraryWebMvc.Models.Publication>
@using System.Text.Json

@{
    ViewData["Title"] = "Index";
}

<h1>Список видань</h1>

<p>
    <a asp-action="Create" class="create-link">Створити</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Назва</th>
            <th>Анотація</th>
            <th>Рік</th>
            <th>Мова</th>
            <th>Тип видання</th>
            <th>Видавництво</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Title)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Annotation)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Year)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Language)
            </td>
                <td>
                    @item.PublicationType?.TypeName
                </td>
                <td>
                    @item.Publisher?.Name
                </td>
            <td>
                    <a asp-action="Edit" asp-route-id="@item.PublicationId" class="action-link">Редагувати</a>
                    <a asp-action="Details" asp-route-id="@item.PublicationId" class="action-link">Детальніше</a>
                    <a asp-action="Delete" asp-route-id="@item.PublicationId" class="action-link">Видалити</a>
            </td>
        </tr>
}
    </tbody>
</table>
<div class="mt-5">
    <h3>Кількість видань за роками</h3>
    <div class="card border-0 shadow-sm mt-3" style="border-radius: 16px; background-color: #ffffff;">
        <div class="card-body">
            <canvas id="publicationsByYearChart" height="110"></canvas>
        </div>
    </div>
</div>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const publicationYearLabels = @Html.Raw(JsonSerializer.Serialize(ViewBag.YearLabels));
        const publicationYearCounts = @Html.Raw(JsonSerializer.Serialize(ViewBag.YearCounts));

        const publicationsByYearCtx = document.getElementById('publicationsByYearChart');

        new Chart(publicationsByYearCtx, {
            type: 'line',
            data: {
                labels: publicationYearLabels,
                datasets: [{
                    label: 'Кількість видань',
                    data: publicationYearCounts,
                    fill: false,
                    tension: 0.25
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: true
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            precision: 0
                        }
                    }
                }
            }
        });
    </script>
}
